{
  "name": "associations",
  "title": "Associations Extension",
  "description": "Extension for associations (non-profit organizations) beneficiaries",
  "fields": [
    {
      "name": "forme_juridique_association",
      "title": "Formes juridiques acceptées",
      "description": "Formes juridiques d'association acceptées (loi 1901, loi Waldeck-Rousseau, etc.)",
      "example": "loi_1901|loi_waldeck_rousseau|cooperative",
      "type": "string"
    },
    {
      "name": "domaine_activite",
      "title": "Domaines d'activité",
      "description": "Domaines d'activité des associations acceptées",
      "example": "culture|sport|environnement|social",
      "type": "string"
    },
    {
      "name": "nombre_membres_minimum",
      "title": "Nombre de membres minimum",
      "description": "Nombre minimum de membres requis",
      "example": "3",
      "type": "integer"
    },
    {
      "name": "anciennete_minimum_mois",
      "title": "Ancienneté minimum (mois)",
      "description": "Nombre de mois minimum d'existence requis",
      "example": "12",
      "type": "integer"
    },
    {
      "name": "statut_employes",
      "title": "Statut d'emploi requis",
      "description": "Association avec ou sans salariés",
      "example": "avec_salaries|sans_salaries|peu_importe",
      "type": "string"
    },
    {
      "name": "budget_minimum",
      "title": "Budget minimum",
      "description": "Budget minimum annuel en euros",
      "example": "10000",
      "type": "number"
    }
  ]
}
